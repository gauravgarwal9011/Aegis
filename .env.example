# Copy to .env and fill in as needed. The DEFAULT (mock) needs NONE of these.

# Provider: mock (default, offline) | anthropic | openai | groq
LLM_PROVIDER=mock
# Model id for the chosen provider (ignored by mock). Leave blank to use the
# per-provider default.
# anthropic: claude-haiku-4-5 (cheap) | claude-sonnet-5 | claude-opus-4-8
# openai:    gpt-4o-mini | gpt-4o
# groq:      llama-3.3-70b-versatile (default) | llama-3.1-8b-instant
LLM_MODEL=

# API keys (only for real providers). If missing, we warn and fall back to mock.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Tracing. Without a token, Logfire is a silent no-op.
LOGFIRE_TOKEN=

# Tunables
CONFIDENCE_THRESHOLD=0.6
MAX_MESSAGE_CHARS=8000
